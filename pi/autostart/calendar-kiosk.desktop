[Desktop Entry]
Type=Application
Name=Calendar Kiosk
Exec=chromium-browser \
  --kiosk \
  --noerrdialogs \
  --disable-infobars \
  --disable-session-crashed-bubble \
  --disable-restore-session-state \
  --no-first-run \
  --check-for-update-interval=31536000 \
  http://localhost/
X-GNOME-Autostart-enabled=true
